{
  "extends": [
    "development"
  ],
  "hints": {
    "axe/forms": "off",
    "axe/name-role-value": "off",
    "no-inline-styles": "off",
    "axe/aria": "off",
    "axe/structure": "off",
    "disown-opener": "off",
    "typescript-config/is-valid": "off",
    "typescript-config/strict": "off",
    "typescript-config/consistent-casing": "off"
  },
  "browserslist": [
    "defaults",
    "not ie 11",
    "not ios_saf <= 18.3",
    "not safari <= 18.3"
  ]
}